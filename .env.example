# Required before production launch
AUTH_SECRET="replace-with-a-long-random-secret"
NEXT_PUBLIC_APP_URL="https://unitydating.net"

# Database provider, for example Postgres/Supabase/Neon.
DATABASE_URL="postgresql://user:password@host:5432/unity"
DATABASE_SSL="true"

# Pi Network payments.
PI_SERVER_API_KEY="replace-with-your-pi-developer-platform-api-key"
NEXT_PUBLIC_PI_SANDBOX="true"
NEXT_PUBLIC_PI_BASIC_AMOUNT="1"
NEXT_PUBLIC_PI_PREMIUM_AMOUNT="2"
NEXT_PUBLIC_PI_ELITE_AMOUNT="3"

# Stripe Billing integration, optional if Pi Network is the only payment rail.
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_BASIC_PRICE_ID="price_..."
STRIPE_PREMIUM_PRICE_ID="price_..."
STRIPE_ELITE_PRICE_ID="price_..."

# Keep false in production after real Stripe is connected.
NEXT_PUBLIC_DEMO_MODE="false"
